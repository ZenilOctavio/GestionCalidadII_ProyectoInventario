<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="CENTER" layoutX="0.0" layoutY="0.0" prefHeight="720.0" prefWidth="1000.0" spacing="20.0" style="-fx-background-color: #f5f5f5;">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>

        <!-- Título -->
        <Label text="Sistema de Inventario" textAlignment="CENTER">
            <font>
                <Font name="System Bold" size="32.0" />
            </font>
        </Label>

        <Label text="Inicie sesión para continuar" textAlignment="CENTER">
            <font>
                <Font size="14.0" />
            </font>
        </Label>

        <!-- Contenedor de login -->
        <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-border-color: #cccccc; -fx-border-radius: 10; -fx-background-color: white; -fx-padding: 40;" maxWidth="400.0">

            <!-- Usuario -->
            <VBox spacing="5.0">
                <Label text="Usuario:" style="-fx-font-weight: bold;">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
                <TextField fx:id="usernameField" promptText="Ingrese su usuario" />
            </VBox>

            <!-- Contraseña -->
            <VBox spacing="5.0">
                <Label text="Contraseña:" style="-fx-font-weight: bold;">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
                <PasswordField fx:id="passwordField" promptText="Ingrese su contraseña" />
            </VBox>

            <!-- Botón login -->
            <Button fx:id="loginButton" alignment="CENTER" prefHeight="40.0" prefWidth="150.0" style="-fx-font-size: 14; -fx-padding: 10; -fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Iniciar sesión" />
        </VBox>
    </VBox>
</AnchorPane>