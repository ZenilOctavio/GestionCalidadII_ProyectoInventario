<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<?import javafx.scene.control.Label?>
<AnchorPane prefHeight="720.0" prefWidth="1000.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <!-- Contenedor principal centrado -->
    <HBox alignment="CENTER" layoutX="0" layoutY="0" prefHeight="720.0" prefWidth="1000.0">
        <!-- Panel de login -->
        <VBox fx:id="loginContainer" alignment="TOP_CENTER" spacing="24" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-padding: 48;" prefHeight="500" prefWidth="400">

            <!-- Logo/Título -->
            <VBox alignment="CENTER" spacing="8">
<!--                <fx:include source="/components/LogoComponent.fxml" />-->
            </VBox>

            <!-- Campos del formulario -->
            <VBox fx:id="formFields" spacing="20" />

            <!-- Botón de login -->
            <VBox fx:id="buttonContainer" spacing="12" />

            <!-- Spacer -->
            <VBox VBox.vgrow="ALWAYS" />

            <!-- Footer -->
            <VBox alignment="CENTER" spacing="4">
                <Label fx:id="footerLabel" text="Sistema de Gestión de Inventario" />
            </VBox>
        </VBox>
    </HBox>
</AnchorPane>