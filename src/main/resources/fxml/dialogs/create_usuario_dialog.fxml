<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="400.0" prefWidth="500.0" spacing="15.0" style="-fx-padding: 20; -fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <!-- Título -->
    <Label text="Crear Nuevo Usuario" style="-fx-font-size: 18; -fx-font-weight: bold;" />

    <!-- Nombre -->
    <VBox spacing="5.0">
        <Label text="Nombre de usuario:" style="-fx-font-weight: bold;" />
        <TextField fx:id="nombreField" promptText="Ingrese el nombre de usuario" />
    </VBox>

    <!-- Contraseña -->
    <VBox spacing="5.0">
        <Label text="Contraseña:" style="-fx-font-weight: bold;" />
        <PasswordField fx:id="passwordField" promptText="Ingrese la contraseña" />
    </VBox>

    <!-- Confirmar Contraseña -->
    <VBox spacing="5.0">
        <Label text="Confirmar contraseña:" style="-fx-font-weight: bold;" />
        <PasswordField fx:id="confirmPasswordField" promptText="Confirme la contraseña" />
    </VBox>

    <!-- Rol -->
    <VBox spacing="5.0">
        <Label text="Rol:" style="-fx-font-weight: bold;" />
        <ComboBox fx:id="rolCombo" prefWidth="300.0" promptText="Seleccione un rol" />
    </VBox>

    <!-- Spacer -->
    <VBox VBox.vgrow="ALWAYS" />

    <!-- Botones -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="cancelButton" style="-fx-font-size: 12; -fx-padding: 10; -fx-background-color: #757575; -fx-text-fill: white; -fx-cursor: hand;" text="Cancelar" />
        <Button fx:id="saveButton" style="-fx-font-size: 12; -fx-padding: 10; -fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand;" text="Guardar" />
    </HBox>
</VBox>