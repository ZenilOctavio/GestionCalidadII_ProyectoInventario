<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="root" prefWidth="500.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
    </padding>

    <!-- Header -->
    <VBox fx:id="headerContainer" spacing="4.0" />

    <!-- Form Fields -->
    <VBox fx:id="formFields" spacing="16.0">
        <VBox fx:id="nombreGroup" spacing="8.0">
            <Label fx:id="nombreLabel" text="Nombre de usuario" />
            <TextField fx:id="nombreField" editable="false" />
        </VBox>

        <VBox fx:id="passwordGroup" spacing="8.0">
            <Label fx:id="passwordLabel" text="Nueva contraseña (opcional)" />
            <PasswordField fx:id="passwordField" />
        </VBox>

        <VBox fx:id="confirmPasswordGroup" spacing="8.0">
            <Label fx:id="confirmPasswordLabel" text="Confirmar contraseña" />
            <PasswordField fx:id="confirmPasswordField" />
        </VBox>

        <VBox fx:id="rolGroup" spacing="8.0">
            <Label fx:id="rolLabel" text="Rol" />
            <ComboBox fx:id="rolCombo" prefWidth="436.0" />
        </VBox>
    </VBox>

    <Label fx:id="errorLabel" managed="false" visible="false" />

    <!-- Action Buttons -->
    <HBox fx:id="buttonContainer" alignment="CENTER_RIGHT" spacing="12.0">
        <Button fx:id="cancelButton" text="Cancelar" />
        <Button fx:id="saveButton" text="Guardar Cambios" />
    </HBox>
</VBox>