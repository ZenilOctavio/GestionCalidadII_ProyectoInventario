<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="500.0" prefWidth="500.0" spacing="15.0" style="-fx-padding: 20; -fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <!-- Título -->
    <Label text="Modificar Producto" style="-fx-font-size: 18; -fx-font-weight: bold;" />

    <!-- ID (solo lectura) -->
    <VBox spacing="5.0">
        <Label text="ID:" style="-fx-font-weight: bold;" />
        <TextField fx:id="idField" editable="false" style="-fx-text-fill: #666;" />
    </VBox>

    <!-- Nombre -->
    <VBox spacing="5.0">
        <Label text="Nombre:" style="-fx-font-weight: bold;" />
        <TextField fx:id="nombreField" promptText="Ingrese el nombre del producto" />
    </VBox>

    <!-- Descripción -->
    <VBox spacing="5.0">
        <Label text="Descripción:" style="-fx-font-weight: bold;" />
        <TextField fx:id="descripcionField" promptText="Ingrese la descripción" />
    </VBox>

    <!-- Precio -->
    <VBox spacing="5.0">
        <Label text="Precio:" style="-fx-font-weight: bold;" />
        <TextField fx:id="precioField" promptText="Ingrese el precio" />
    </VBox>

    <!-- Cantidad -->
    <VBox spacing="5.0">
        <Label text="Cantidad:" style="-fx-font-weight: bold;" />
        <TextField fx:id="cantidadField" promptText="Ingrese la cantidad" />
    </VBox>

    <!-- Almacén -->
    <VBox spacing="5.0">
        <Label text="Almacén:" style="-fx-font-weight: bold;" />
        <ComboBox fx:id="almacenCombo" prefWidth="300.0" promptText="Seleccione un almacén" />
    </VBox>

    <!-- Botones -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="cancelButton" style="-fx-font-size: 12; -fx-padding: 10; -fx-background-color: #757575; -fx-text-fill: white; -fx-cursor: hand;" text="Cancelar" />
        <Button fx:id="saveButton" style="-fx-font-size: 12; -fx-padding: 10; -fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;" text="Guardar cambios" />
    </HBox>
</VBox>