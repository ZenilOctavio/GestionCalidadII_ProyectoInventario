<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>

<AnchorPane fx:id="root" prefHeight="720.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <VBox fx:id="mainContainer" prefHeight="720.0" prefWidth="1000.0">
        
        <!-- Header / Navigation Bar -->
        <HBox fx:id="headerBar" alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0">
            <padding>
                <Insets left="40.0" right="40.0" />
            </padding>
            <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <Label fx:id="welcomeLabel" text="Panel de Control" />
                <Label fx:id="dateLabel" text="Sistema de Inventario" />
            </VBox>
            
            <HBox alignment="CENTER_RIGHT" spacing="20.0">
                <VBox alignment="CENTER_RIGHT">
                    <Label fx:id="usuarioLabel" text="Nombre Usuario" />
                    <Label fx:id="rolLabel" text="Administrador" />
                </VBox>
                <Button fx:id="logoutButton" text="Cerrar Sesión" />
            </HBox>
        </HBox>

        <!-- Main Content Area -->
        <VBox alignment="CENTER" spacing="40.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="40.0" left="60.0" right="60.0" top="20.0" />
            </padding>

            <Label fx:id="sectionTitle" text="¿Qué deseas gestionar hoy?" />

            <HBox alignment="CENTER" spacing="32.0">
                <!-- Card Productos -->
                <VBox fx:id="productosCard" alignment="TOP_CENTER" prefHeight="300.0" prefWidth="240.0" spacing="20.0">
                    <padding>
                        <Insets bottom="30.0" left="20.0" right="20.0" top="40.0" />
                    </padding>
                    <StackPane fx:id="productosIconContainer" prefHeight="80.0" prefWidth="80.0" />
                    <VBox alignment="CENTER" spacing="8.0">
                        <Label fx:id="productosTitle" text="Productos" />
                        <Label fx:id="productosDesc" alignment="CENTER" text="Catálogo, precios y control de existencias" textAlignment="CENTER" wrapText="true" />
                    </VBox>
                    <VBox VBox.vgrow="ALWAYS" />
                    <Button fx:id="productosButton" text="Gestionar" />
                </VBox>

                <!-- Card Almacenes -->
                <VBox fx:id="almacenesCard" alignment="TOP_CENTER" prefHeight="300.0" prefWidth="240.0" spacing="20.0">
                    <padding>
                        <Insets bottom="30.0" left="20.0" right="20.0" top="40.0" />
                    </padding>
                    <StackPane fx:id="almacenesIconContainer" prefHeight="80.0" prefWidth="80.0" />
                    <VBox alignment="CENTER" spacing="8.0">
                        <Label fx:id="almacenesTitle" text="Almacenes" />
                        <Label fx:id="almacenesDesc" alignment="CENTER" text="Ubicaciones físicas y organización de depósitos" textAlignment="CENTER" wrapText="true" />
                    </VBox>
                    <VBox VBox.vgrow="ALWAYS" />
                    <Button fx:id="almacenesButton" text="Gestionar" />
                </VBox>

                <!-- Card Usuarios -->
                <VBox fx:id="usuariosCard" alignment="TOP_CENTER" prefHeight="300.0" prefWidth="240.0" spacing="20.0">
                    <padding>
                        <Insets bottom="30.0" left="20.0" right="20.0" top="40.0" />
                    </padding>
                    <StackPane fx:id="usuariosIconContainer" prefHeight="80.0" prefWidth="80.0" />
                    <VBox alignment="CENTER" spacing="8.0">
                        <Label fx:id="usuariosTitle" text="Usuarios" />
                        <Label fx:id="usuariosDesc" alignment="CENTER" text="Control de accesos y roles del personal" textAlignment="CENTER" wrapText="true" />
                    </VBox>
                    <VBox VBox.vgrow="ALWAYS" />
                    <Button fx:id="usuariosButton" text="Gestionar" />
                </VBox>
            </HBox>
        </VBox>
        
        <!-- Footer -->
        <HBox alignment="CENTER" prefHeight="40.0">
            <Label fx:id="footerLabel" text="v1.0 Lyra Light Edition" />
        </HBox>
    </VBox>
</AnchorPane>