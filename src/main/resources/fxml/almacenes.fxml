<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="root" prefHeight="720.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <VBox fx:id="mainContainer" layoutX="0.0" layoutY="0.0" prefHeight="720.0" prefWidth="1000.0" spacing="24.0">
        <padding>
            <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
        </padding>

        <!-- Header Section -->
        <HBox fx:id="headerContainer" alignment="CENTER_LEFT" spacing="16.0">
            <VBox fx:id="titleContainer" spacing="4.0" HBox.hgrow="ALWAYS" />
            <HBox fx:id="actionButtonsContainer" alignment="CENTER_RIGHT" spacing="12.0" />
        </HBox>

        <!-- Table Section -->
        <VBox fx:id="tableContainer" spacing="16.0" VBox.vgrow="ALWAYS">
            <TableView fx:id="almacenesTable" prefHeight="500.0" prefWidth="936.0" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
                    <TableColumn fx:id="nombreColumn" prefWidth="450.0" text="Nombre del Almacén" />
                    <TableColumn fx:id="fechaCreacionColumn" prefWidth="250.0" text="Fecha de Registro" />
                    <TableColumn fx:id="ultimoUsuarioColumn" prefWidth="156.0" text="Modificado por" />
                </columns>
                <placeholder>
                    <Label fx:id="placeholderLabel" text="No hay almacenes registrados" />
                </placeholder>
            </TableView>
        </VBox>

        <!-- Footer Section -->
        <HBox fx:id="footerContainer" alignment="CENTER_LEFT">
            <Button fx:id="backButton" text="← Volver al Inicio" />
        </HBox>
    </VBox>
</AnchorPane>